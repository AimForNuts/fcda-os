# Supabase
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable API key (replaces legacy anon key) — safe to expose in browser
# Dashboard → Project Settings → API → Publishable API key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Secret API key (replaces legacy service_role key) — server-side only, never expose publicly
# Dashboard → Project Settings → API → Secret API key
SUPABASE_SECRET_KEY=your-secret-key
